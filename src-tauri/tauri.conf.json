{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "R-Markdown",
  "version": "0.1.22",
  "identifier": "com.robocopmao.r-markdown",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cross-env VITE_TAURI=true pnpm run dev",
    "beforeBuildCommand": "cross-env VITE_TAURI=true pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "R-Markdown",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/robocopmao/r-markdown/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxQzlGQjI0ODQwRkRDNjQKUldSazNBK0VKUHZKSWZ1YXdaRE83MTN2UkVKMmE2NlgzcjY2MVZrVWVzc0lSMVVmRzd1RnZqR0sK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
